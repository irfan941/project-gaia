# Fallback AI — Claude (only used when Gemini hits quota)
ANTHROPIC_API_KEY=sk-ant-your-key-here

DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5433/gaia

# Optional customization
CLAUDE_MODEL=claude-sonnet-4-6
ASSISTANT_NAME=Gaia
USER_NAME=Irfan
MAX_CONTEXT_DOCS=5
